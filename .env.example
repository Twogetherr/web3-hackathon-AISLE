# OpenAI
OPENAI_API_KEY=sk-fake-openai-key-1234567890abcdef

# Database
DATABASE_URL=postgresql://aisle_user:aisle_pass@localhost:5432/aisle_db

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43114
AVALANCHE_FUJI_CHAIN_ID=43113
USDC_CONTRACT_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
USDC_FUJI_CONTRACT_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
MERCHANT_WALLET_ADDRESS=0xFakeM3rchantWall3tAddr3ss0000000000000001
MERCHANT_WALLET_PRIVATE_KEY=0xfake_private_key_never_commit_this_000000

# App
PORT=3001
# Used by the Express server (validated at startup). The browser client may omit this:
# when unset, the Vite dev server proxies /api to VITE_DEV_API_PROXY_TARGET (default http://127.0.0.1:PORT).
VITE_API_BASE_URL=http://localhost:3001
# Optional: where Vite proxies /api during `npm run dev` in client/ (defaults to http://127.0.0.1:3001).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001
NODE_ENV=development
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
