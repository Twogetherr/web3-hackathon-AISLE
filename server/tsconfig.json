{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node", "vitest/globals"],
    "composite": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
